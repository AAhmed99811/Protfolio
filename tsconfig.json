{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "jsx": "react-jsx",
        "moduleResolution": "bundler",
        "baseUrl": ".",
        "paths": {
            "#components/*": [
                "src/components/*"
            ],
            "#constants/*": [
                "src/constants/*"
            ],
            "#store/*": [
                "src/store/*"
            ],
            "#hoc/*": [
                "src/hoc/*"
            ],
            "#windows/*": [
                "src/windows/*"
            ]
        }
    },
    "include": [
        "src"
    ]
}